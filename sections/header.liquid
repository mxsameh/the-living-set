{{ 's-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'j-header.js' | asset_url }}" defer="defer"></script>

<div class="h_">
  <div class="h-ph"></div>

  <header id="h" class="h">
    <!-- Header Left -->
    <div class="h_l">
      <a href="/">
        <img src="{{ 'im-emb-b.png' | asset_url  }}" width="auto" height="auto" alt="logo">
      </a>

      {% comment %}
          {% render 'menu-icon' %}
        <nav class="h_n">
          {% for link in linklists['main-menu'].links -%}
            <div class="h_n-item">
              {{ link.title | link_to: link.url }}
            </div>
          {%- endfor %}
        </nav>
      {% endcomment %}
    </div>

    {% comment %}
      <!-- Header Middle -->
       <div class="h_m">
        <a href="/">
          {% if settings.logo %}
            <figure>
              {{ settings.logo | image_url: width: 200 | image_tag }}
            </figure>
          {% else %}
            <span>
              {{ shop.name }}
            </span>
          {% endif %}
        </a>
      </div>
    {% endcomment %}

    <!-- Header Right -->
    <div class="h_r">
      {% comment %} <div id="search-btn">SEARCH</div> {% endcomment %}
      <nav class="h_n">
        {% for link in linklists['main-menu'].links -%}
          <div class="h_n-item">
            {{ link.title | link_to: link.url }}
          </div>
        {%- endfor %}
      </nav>
      {% comment %} <div>{{ 'LOGIN' | link_to: routes.account_login_url }}</div> {% endcomment %}
      <button id="cart-btn" class="h_cb" type="button">
        Cart (<span id="cart-count" class="h_cb_count">{{- cart.item_count -}}</span>)
      </button>
    </div>

    <div class="h_r-m">
      <div id="search-btn">
        {{ 'i-search.svg' | inline_asset_content }}
      </div>
      <div id="cart-btn">
        {{ 'i-bag.svg' | inline_asset_content }}
        <div class="h_r-m_cc" id="cart-count">{{- cart.item_count -}}</div>
      </div>
    </div>
  </header>

  <!-- MENU DRAWER -->
  {% render 'menu-drawer' %}

  <!-- SEARCH MODAL -->
  {% render 'search-modal' %}
</div>

{% schema %}
{
  "name": "header",
  "settings": []
}
{% endschema %}
